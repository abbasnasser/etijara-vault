meta {
  name: POST /api/v1/products
  type: http
  seq: 2
}

post {
  url: {{base_url}}/api/v1/products
  body: json
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

body:json {
{
  "product": {
    "title": "Sample Title",
    "handle": "",
