    "vendor": null,
    "product_type": null,
    "tags": null,
    "status": "active",
    "options": [{
      "name": "",
      "position": 0,
      "values": []
    }],
    "variants": [{
      "title": "Sample Title",
      "option1": null,
      "option2": null,
      "option3": null,
      "price": "29.99",
      "compare_at_price": "29.99",
      "cost": "29.99",
      "sku": null,
      "barcode": null,
      "inventory_quantity": 0,
      "inventory_policy": "",
      "inventory_management": "",
