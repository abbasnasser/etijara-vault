meta {
  name: POST /api/v1/products/:id/images
  type: http
  seq: 8
}

post {
  url: {{base_url}}/api/v1/products/:id/images
  body: json
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

body:json {
{
  "image": {
    "src": "https://example.com/image.jpg",
