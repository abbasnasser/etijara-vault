meta {
  name: POST /api/v1/auth/reset-password
  type: http
  seq: 5
}

post {
  url: {{base_url}}/api/v1/auth/reset-password
  body: json
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

body:json {
{
  "email": "user@example.com",
  "otp": "123456",
  "newPassword": "yourpassword123"
}
}
