meta {
  name: POST /api/v1/auth/signup
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/v1/auth/signup
  body: json
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

body:json {
{
  "email": "user@example.com",
  "password": "yourpassword123",
  "firstName": "John",
  "lastName": "Doe"
}
}
